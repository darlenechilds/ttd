# calculated theoretical DO using Weiss 1970 solubility constants
T_k <- d$CTDTMP+273.15
s <- d$CTDSAL
Ln_F <- -173.4965+249.6339*(100/T_k)+143.3483*log(T_k/100)+-21.8492*(T_k/100)+
s*(-0.033096+0.014259*(T_k/100)+-0.0017000*(T_k/100)^2)
