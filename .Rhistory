mean <- mean(e$OXYGEN, na.rm = TRUE)
sd  <- sd(e$OXYGEN, na.rm = TRUE)
anomaly  <- mean - nvlsw_ave_ocads
n <- length(e$EXPOCODE)
e_df <- data.frame(year = yr,
mean = mean,
sd = sd,
anomaly = anomaly,
n = n)
s_nv <- rbind(s_nv, e_df)
}
