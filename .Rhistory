# remove nas
o2 <- o2[!is.na(o2$OXYGEN_umolperkg), ]
dups <- o2[duplicated(o2$SAMPNO) | duplicated(o2$SAMPNO, fromLast = TRUE), ]
ind <- which(o2$SAMPNO %in% dups$SAMPNO)
# compute mean + sd for o2 per SAMPNO
stats <- aggregate(OXYGEN_mlperl ~ SAMPNO, data = dups,
FUN = function(x) c(mean = mean(x, na.rm = TRUE),
sd   = sd(x, na.rm = TRUE)))
stats$o2_mean <- stats$OXYGEN_mlperl[, "mean"]
stats$o2_sd   <- stats$OXYGEN_mlperl[, "sd"]
stats$OXYGEN_mlperl <- NULL
o2_needslookinginto <- stats[which(stats$o2_sd>1),]
o2_good <- stats[which(stats$o2_sd<1),]
o2_good <- rbind(o2_good,keep_1st_o2)
o2_removeo2lessthan1 <-  o2_needslookinginto[-which(o2_needslookinginto$OXYGEN_mlperl<1),]    #bad measurement
o2_removeo2lessthan1 <-  o2_needslookinginto[-which(o2_needslookinginto$OXYGEN_mlperl<1),]    #bad measurement
keep_1st_o2 <- o2_removeo2lessthan1[!duplicated(o2_removeo2lessthan1$SAMPNO,fromLast = TRUE),]    #keep first
ind1 <- which(o2$SAMPNO %in% o2_needslookinginto$SAMPNO)
o2_needslookinginto <- o2[ind1,]
o2_removeo2lessthan1 <-  o2_needslookinginto[-which(o2_needslookinginto$OXYGEN_mlperl<1),]    #bad measurement
o2_keep_1st <- o2_removeo2lessthan1[!duplicated(o2_removeo2lessthan1$SAMPNO,fromLast = TRUE),]    #keep first
o2_good <- rbind(o2_good,keep_1st_o2)
head(o2_good)
head(o2)
