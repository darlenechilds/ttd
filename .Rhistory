#libaries
library(oce)
#functions
source("R/read_ocads.r")
source("R/read_ocads_file.r")
source("R/clean_o2.r")
source("R/clean_tracer_cfc12.r")
source("R/clean_tracer_sf6.r")
source("R/clean_carbon_ta.r")
source("R/clean_carbon_tic.r")
