dir()
d <- read.csv("2024_ds_stns.csv", stringsAsFactors = F, header = F)
s <- read.csv("2024_ls_stns.csv", stringsAsFactors = F, header = F)
head(s)
lat <- d$V1
long <- d$V2
lat1 <- s$V1
long1 <- s$V2
par(mar=c(4,4,1,1),mfrow=c(1,1))
plot(coastlineWorldMedium, clongitude=-57, clatitude= 61.5, span=2500)
points(long,lat,pch = 19)#,xlim = c(-70,-60), ylim = c(41,44))
points(long1,lat1,pch = 19, col = "red")#,xlim = c(-70,-60), ylim = c(41,44))
# plot bathymetry
contour(bathyLon,bathyLat,bathyZ,
levels = c(-100, -250, -1000, -2000, -4500),
lwd = c(1, 1, 2, 2, 3),
lty = c(3, 1, 3, 1, 3),
drawlabels = F, add = TRUE, col = 'darkgray')
# add depth legend
legend("bottomleft", seg.len = 3, cex = 0.8,
lwd = c(1, 1, 2, 2, 3),
lty = c(3, 1, 3, 1, 3),
legend = c("100", "250", "1000", "2000", "4500"),
col = 'darkgray', title = "Depth [m]", bg= "white")
plot(coastlineWorldMedium, clongitude=-57, clatitude= 61.5, span=5000)
