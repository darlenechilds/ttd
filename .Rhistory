d <- read.csv("DO_withmeta.csv",header =  T, stringsAsFactors = F)   #read in data
head(d)
T_k <- d$Temp..Oc.+273.15
s <- d$Salinity
d$Ln_F <- -173.4965+249.6339*(100/T_k)+143.3483*log(T_k/100)+-21.8492*(T_k/100)+s*(-0.033096+0.014259*(T_k/100)+-0.0017000*(T_k/100)^2)
d$eF <- exp(d$Ln_F)
# do_sat <- d$DO/eF*100
d$aou <- d$eF-d$DO
ustn <- unique(d$stn)
i <- ustn[3]
for(i in ustn){
e <- d[which(d$stn==i),]
do <- e$DO
do_sol <- e$eF
s <- e$Salinity
t <- e$Temp..Oc.
p <- e$Depth
par(mfrow = c(1,3), mar = c(5, 2, 3, 1 ))
plot(do, -p, xlim = c(6, 9), ylim = c(-3800,0), pch = 16, main = i)
points(do_sol,-p,pch = 16, col = "blue")
plot(s, -p, xlim = c(30, 35), ylim = c(-3800,0),pch = 16)
plot(t, -p, xlim = c(-1.5, 15), ylim = c(-3800,0),pch = 16)
}
