i <- ucruise[2]
ustn <- as.numeric(unique(e$STNNBR))
e <- d[which(d$EXPOCODE==i),]
ustn <- as.numeric(unique(e$STNNBR))
j <- ustn[1]
f <- e[which(e$STNNBR==j),]
par(mfrow = c(1,3), mar = c(5, 2, 3, 1 ))
